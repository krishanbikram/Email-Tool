# ─── Copy this to .env.prod on your server and fill in real values ──────────

# Database
DB_USER=emailtool
DB_PASSWORD=CHANGE_ME_strong_db_password_here
DB_NAME=emailtool

# Redis
REDIS_PASSWORD=CHANGE_ME_strong_redis_password_here

# App
NODE_ENV=production
PORT=4000

# Auth — generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
JWT_EXPIRES_IN=7d

# Encryption — EXACTLY 32 characters
AES_SECRET_KEY=CHANGE_ME_exactly_32_chars_here!

# Admin seed credentials (used only on first run)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# Public URL of your server (your domain or IP)
APP_BASE_URL=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com
