# ─── Database ────────────────────────────────────────────────────────────────
DB_USER=emailtool
DB_PASSWORD=emailtool123
DB_NAME=emailtool
DATABASE_URL=postgresql://emailtool:emailtool123@localhost:5432/emailtool

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret_string_at_least_64_chars
JWT_EXPIRES_IN=7d

# ─── Encryption (AES-256, must be exactly 32 chars) ──────────────────────────
AES_SECRET_KEY=change_me_32_chars_exactly_here!!

# ─── Admin Seed Credentials ──────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123456

# ─── Tracking Base URL (your public domain or localhost for dev) ──────────────
APP_BASE_URL=http://localhost:4000

# ─── Frontend URL (for CORS) ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Email Notifications (admin alerts) ──────────────────────────────────────
NOTIFY_EMAIL=admin@example.com
NOTIFY_SMTP_HOST=smtp.example.com
NOTIFY_SMTP_PORT=587
NOTIFY_SMTP_USER=alerts@example.com
NOTIFY_SMTP_PASS=your_notify_smtp_password
